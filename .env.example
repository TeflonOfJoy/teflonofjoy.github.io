# Notion (CMS for Stack, Sites, TIL, Book Digest, Design Details)
NOTION_TOKEN=secret_xxx
NOTION_STACK_DATABASE_ID=
NOTION_GOOD_WEBSITES_DATABASE_ID=
NOTION_TIL_DATABASE_ID=
NOTION_BOOK_DIGEST_DATABASE_ID=
NOTION_DESIGN_DETAILS_EPISODES_DATABASE_ID=
# Secret for authenticating Notion automation webhooks
# Configure in Notion automation: Add header "x-webhook-secret" with this value
NOTION_WEBHOOK_VERIFICATION_SECRET=

# Cloudflare R2 (site/stack preview images uploaded by Notion webhooks)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_S3_API_URL=

# Upstash Redis (Notion content cache) — optional but recommended
UPSTASH_NOTION_CACHE_REST_URL=
UPSTASH_NOTION_CACHE_REST_TOKEN=

# Upstash Redis (Likes) — used by Stack, Sites, TIL, Design Details
UPSTASH_LIKES_REST_URL=
UPSTASH_LIKES_REST_TOKEN=

# Likes system
LIKES_HASH_SALT=
# Optional: token to authorize the /api/likes/sync endpoint
LIKES_SYNC_TOKEN=

# Optional: secret to authorize the /api/purge-cache endpoint
CACHE_PURGE_SECRET=
